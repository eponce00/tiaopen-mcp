<?xml version="1.0" encoding="utf-8"?>
<!--
  Template: lad/two-network.xml
  Purpose : LAD block with two independent rungs (networks).
            Rung 1: XIC contact → coil.  Rung 2: XIC contact → coil.
            Demonstrates multi-network structure — all templates can be combined
            using this ID spacing pattern (each network offsets IDs by 100).
  Status  : PENDING VERIFICATION

  TOKENS:
    {{BLOCK_NAME}}        - e.g. "FC_TwoRung"
    {{BLOCK_NUMBER}}      - e.g. "224"
    {{BLOCK_TYPE}}        - SW.Blocks.OB | SW.Blocks.FC | SW.Blocks.FB
    Rung 1:
    {{INPUT_AREA}}        - Area for rung 1 contact
    {{INPUT_BITOFFSET}}   - Bit offset for rung 1 contact
    {{OUTPUT_AREA}}       - Area for rung 1 coil
    {{OUTPUT_BITOFFSET}}  - Bit offset for rung 1 coil
    Rung 2:
    {{INPUT2_AREA}}       - Area for rung 2 contact
    {{INPUT2_BITOFFSET}}  - Bit offset for rung 2 contact
    {{OUTPUT2_AREA}}      - Area for rung 2 coil (re-uses OUTPUT_AREA token family)
    {{OUTPUT2_BITOFFSET}} - Bit offset for rung 2 coil

  Note: Multi-network rule — each CompileUnit gets its own ID block.
        Network 1 uses IDs 3, 4-9, 21-39. Network 2 uses IDs 10, 11-19, 121-139.
        IDs must be unique across the whole document.

  Example call:
    .\scripts\new-block.ps1 -Template templates\lad\two-network.xml `
      -BlockName FC_TwoRung -BlockNumber 224 -BlockType SW.Blocks.FC `
      -InputArea Input -InputBitOffset 0 -OutputArea Output -OutputBitOffset 0 `
      -Input2Area Input -Input2BitOffset 1 -Output2Area Output -Output2BitOffset 1
-->
<Document>
  <Engineering version="V20" />
  <{{BLOCK_TYPE}} ID="0">
    <AttributeList>
      <AutoNumber>false</AutoNumber>
      <HeaderAuthor />
      <HeaderFamily />
      <HeaderName />
      <HeaderVersion>0.1</HeaderVersion>
      <Interface><Sections xmlns="http://www.siemens.com/automation/Openness/SW/Interface/v5">
  <Section Name="Input" />
  <Section Name="Output" />
  <Section Name="InOut" />
  <Section Name="Temp" />
  <Section Name="Constant" />
  <Section Name="Return">
    <Member Name="Ret_Val" Datatype="Void" Accessibility="Public" />
  </Section>
</Sections></Interface>
      <IsIECCheckEnabled>false</IsIECCheckEnabled>
      <MemoryLayout>Optimized</MemoryLayout>
      <Name>{{BLOCK_NAME}}</Name>
      <Namespace />
      <Number>{{BLOCK_NUMBER}}</Number>
      <ProgrammingLanguage>LAD</ProgrammingLanguage>
      <SetENOAutomatically>false</SetENOAutomatically>
    </AttributeList>
    <ObjectList>
      <MultilingualText ID="1" CompositionName="Comment">
        <ObjectList>
          <MultilingualTextItem ID="2" CompositionName="Items">
            <AttributeList>
              <Culture>en-US</Culture>
              <Text />
            </AttributeList>
          </MultilingualTextItem>
        </ObjectList>
      </MultilingualText>

      <!-- ── Network 1 (IDs 3..9, parts 21..39) ───────────────────────── -->
      <SW.Blocks.CompileUnit ID="3" CompositionName="CompileUnits">
        <AttributeList>
          <NetworkSource><FlgNet xmlns="http://www.siemens.com/automation/Openness/SW/NetworkSource/FlgNet/v5">
  <Parts>
    <Access Scope="Address" UId="21">
      <Address Area="{{INPUT_AREA}}" Type="Bool" BitOffset="{{INPUT_BITOFFSET}}" />
    </Access>
    <Access Scope="Address" UId="22">
      <Address Area="{{OUTPUT_AREA}}" Type="Bool" BitOffset="{{OUTPUT_BITOFFSET}}" />
    </Access>
    <Part Name="Contact" UId="23" />
    <Part Name="Coil" UId="24" />
  </Parts>
  <Wires>
    <Wire UId="30">
      <Powerrail />
      <NameCon UId="23" Name="in" />
    </Wire>
    <Wire UId="31">
      <IdentCon UId="21" />
      <NameCon UId="23" Name="operand" />
    </Wire>
    <Wire UId="32">
      <NameCon UId="23" Name="out" />
      <NameCon UId="24" Name="in" />
    </Wire>
    <Wire UId="33">
      <IdentCon UId="22" />
      <NameCon UId="24" Name="operand" />
    </Wire>
  </Wires>
</FlgNet></NetworkSource>
          <ProgrammingLanguage>LAD</ProgrammingLanguage>
        </AttributeList>
        <ObjectList>
          <MultilingualText ID="4" CompositionName="Comment">
            <ObjectList>
              <MultilingualTextItem ID="5" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text />
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
          <MultilingualText ID="6" CompositionName="Title">
            <ObjectList>
              <MultilingualTextItem ID="7" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text>Rung 1</Text>
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
        </ObjectList>
      </SW.Blocks.CompileUnit>

      <!-- ── Network 2 (IDs 10..19, parts 121..139) ──────────────────── -->
      <SW.Blocks.CompileUnit ID="10" CompositionName="CompileUnits">
        <AttributeList>
          <NetworkSource><FlgNet xmlns="http://www.siemens.com/automation/Openness/SW/NetworkSource/FlgNet/v5">
  <Parts>
    <Access Scope="Address" UId="121">
      <Address Area="{{INPUT2_AREA}}" Type="Bool" BitOffset="{{INPUT2_BITOFFSET}}" />
    </Access>
    <Access Scope="Address" UId="122">
      <Address Area="{{OUTPUT2_AREA}}" Type="Bool" BitOffset="{{OUTPUT2_BITOFFSET}}" />
    </Access>
    <Part Name="Contact" UId="123" />
    <Part Name="Coil" UId="124" />
  </Parts>
  <Wires>
    <Wire UId="130">
      <Powerrail />
      <NameCon UId="123" Name="in" />
    </Wire>
    <Wire UId="131">
      <IdentCon UId="121" />
      <NameCon UId="123" Name="operand" />
    </Wire>
    <Wire UId="132">
      <NameCon UId="123" Name="out" />
      <NameCon UId="124" Name="in" />
    </Wire>
    <Wire UId="133">
      <IdentCon UId="122" />
      <NameCon UId="124" Name="operand" />
    </Wire>
  </Wires>
</FlgNet></NetworkSource>
          <ProgrammingLanguage>LAD</ProgrammingLanguage>
        </AttributeList>
        <ObjectList>
          <MultilingualText ID="11" CompositionName="Comment">
            <ObjectList>
              <MultilingualTextItem ID="12" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text />
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
          <MultilingualText ID="13" CompositionName="Title">
            <ObjectList>
              <MultilingualTextItem ID="14" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text>Rung 2</Text>
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
        </ObjectList>
      </SW.Blocks.CompileUnit>

      <MultilingualText ID="8" CompositionName="Title">
        <ObjectList>
          <MultilingualTextItem ID="9" CompositionName="Items">
            <AttributeList>
              <Culture>en-US</Culture>
              <Text />
            </AttributeList>
          </MultilingualTextItem>
        </ObjectList>
      </MultilingualText>
    </ObjectList>
  </{{BLOCK_TYPE}}>
</Document>
