    <Access Scope="LiteralConstant" UId="23">
      <Constant>
        <ConstantType>Time</ConstantType>
        <ConstantValue>{{PRESET_TIME}}</ConstantValue>
      </Constant>
    </Access>
    <Part Name="Contact" UId="24" />
    <Part Name="TON_TIME" UId="25">
      <Instance Scope="GlobalVariable" UId="26">
        <Component Name="Timer1" />
      </Instance>
    </Part>
    <Part Name="Coil" UId="27" />
  </Parts>
  <Wires>
    <Wire UId="30">
      <Powerrail />
      <NameCon UId="24" Name="in" />
    </Wire>
    <Wire UId="31">
      <NameCon UId="24" Name="out" />
      <NameCon UId="25" Name="IN" />
    </Wire>
    <Wire UId="32">
      <NameCon UId="25" Name="Q" />
      <NameCon UId="27" Name="in" />
    </Wire>
    <Wire UId="33">
      <IdentCon UId="21" />
      <NameCon UId="24" Name="operand" />
    </Wire>
    <Wire UId="34">
      <IdentCon UId="23" />
      <NameCon UId="25" Name="PT" />
    </Wire>
    <Wire UId="35">
      <IdentCon UId="22" />
      <NameCon UId="27" Name="operand" />
    </Wire>
  </Wires>
</FlgNet></NetworkSource>
          <ProgrammingLanguage>LAD</ProgrammingLanguage>
        </AttributeList>
        <ObjectList>
          <MultilingualText ID="4" CompositionName="Comment">
            <ObjectList>
              <MultilingualTextItem ID="5" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text />
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
          <MultilingualText ID="6" CompositionName="Title">
            <ObjectList>
              <MultilingualTextItem ID="7" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text>{{NETWORK_TITLE}}</Text>
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
        </ObjectList>
      </SW.Blocks.CompileUnit>
    </ObjectList>
  </{{BLOCK_TYPE}}>
</Document>
