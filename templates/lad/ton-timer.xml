    IdentCon(Access:preset) → NameCon(TON_TIME, "PT")
    IdentCon(Access:done) → NameCon(Coil, "operand")

  NOTE: TON_TIME is the S7-1200/1500 IEC timer instruction name.
        Instance DB is auto-created by TIA when block is imported.
-->
<Document>
  <Engineering version="V20" />
  <{{BLOCK_TYPE}} ID="0">
    <AttributeList>
      <AutoNumber>false</AutoNumber>
      <HeaderAuthor />
      <HeaderFamily />
      <HeaderName />
      <HeaderVersion>0.1</HeaderVersion>
