<?xml version="1.0" encoding="utf-8"?>
<!--
  Template: lad/move.xml
  Purpose : Single rung — Enable contact → MOVE instruction (copies IN to OUT1).
  Status  : VERIFIED — import + compile → Success, 0 errors (TIA Portal V20 Update 4)

  TOKENS:
    {{BLOCK_NAME}}         – e.g. "FC_MoveTest"
    {{BLOCK_NUMBER}}       – e.g. "211"
    {{BLOCK_TYPE}}         – SW.Blocks.OB | SW.Blocks.FC | SW.Blocks.FB
    {{NETWORK_TITLE}}      – Free text title for the network rung
    {{ENABLE_AREA}}        – Input | Output | Memory  (enable contact)
    {{ENABLE_BITOFFSET}}   – Bit offset for enable contact, e.g. "0"
    {{SRC_AREA}}           – Input | Output | Memory  (MOVE IN source)
    {{SRC_BITOFFSET}}      – Bit offset for source word (byte-aligned), e.g. "0"  (word = BitOffset/8 = byte addr)
    {{DST_AREA}}           – Output | Memory  (MOVE OUT1 destination)
    {{DST_BITOFFSET}}      – Bit offset for destination word, e.g. "16"
    {{DATA_TYPE}}          – Int | Word | DInt | DWord | Real | etc.

  Wire topology:
    Powerrail → NameCon(Contact, "in")
    NameCon(Contact, "out") → NameCon(Move, "en")
    NameCon(Move, "eno") → OpenCon  (ENO unused)
    IdentCon(Access:enable) → NameCon(Contact, "operand")
    IdentCon(Access:src) → NameCon(Move, "in")
    IdentCon(Access:dst) → NameCon(Move, "out1")

  Notes:
    - Part Name="Move" (capital M)
    - ENO pin wired to OpenCon if not used downstream
-->
<Document>
  <Engineering version="V20" />
  <{{BLOCK_TYPE}} ID="0">
    <AttributeList>
      <AutoNumber>false</AutoNumber>
      <HeaderAuthor />
      <HeaderFamily />
      <HeaderName />
      <HeaderVersion>0.1</HeaderVersion>
      <Interface><Sections xmlns="http://www.siemens.com/automation/Openness/SW/Interface/v5">
  <Section Name="Temp" />
  <Section Name="Constant" />
</Sections></Interface>
      <IsIECCheckEnabled>false</IsIECCheckEnabled>
      <MemoryLayout>Optimized</MemoryLayout>
      <Name>{{BLOCK_NAME}}</Name>
      <Namespace />
      <Number>{{BLOCK_NUMBER}}</Number>
      <ProgrammingLanguage>LAD</ProgrammingLanguage>
      <SetENOAutomatically>false</SetENOAutomatically>
    </AttributeList>
    <ObjectList>
      <MultilingualText ID="1" CompositionName="Comment">
        <ObjectList>
          <MultilingualTextItem ID="2" CompositionName="Items">
            <AttributeList>
              <Culture>en-US</Culture>
              <Text />
            </AttributeList>
          </MultilingualTextItem>
        </ObjectList>
      </MultilingualText>
      <SW.Blocks.CompileUnit ID="3" CompositionName="CompileUnits">
        <AttributeList>
          <NetworkSource><FlgNet xmlns="http://www.siemens.com/automation/Openness/SW/NetworkSource/FlgNet/v5">
  <Parts>
    <Access Scope="Address" UId="21">
      <Address Area="{{ENABLE_AREA}}" Type="Bool" BitOffset="{{ENABLE_BITOFFSET}}" />
    </Access>
    <Access Scope="Address" UId="22">
      <Address Area="{{SRC_AREA}}" Type="{{DATA_TYPE}}" BitOffset="{{SRC_BITOFFSET}}" />
    </Access>
    <Access Scope="Address" UId="23">
      <Address Area="{{DST_AREA}}" Type="{{DATA_TYPE}}" BitOffset="{{DST_BITOFFSET}}" />
    </Access>
    <Part Name="Contact" UId="24" />
    <Part Name="Move" UId="25">
      <TemplateValue Name="Card" Type="Cardinality">1</TemplateValue>
    </Part>
  </Parts>
  <Wires>
    <Wire UId="30">
      <Powerrail />
      <NameCon UId="24" Name="in" />
    </Wire>
    <Wire UId="31">
      <NameCon UId="24" Name="out" />
      <NameCon UId="25" Name="en" />
    </Wire>
    <Wire UId="32">
      <NameCon UId="25" Name="eno" />
      <OpenCon UId="33" />
    </Wire>
    <Wire UId="34">
      <IdentCon UId="21" />
      <NameCon UId="24" Name="operand" />
    </Wire>
    <Wire UId="35">
      <IdentCon UId="22" />
      <NameCon UId="25" Name="in" />
    </Wire>
    <Wire UId="36">
      <IdentCon UId="23" />
      <NameCon UId="25" Name="out1" />
    </Wire>
  </Wires>
</FlgNet></NetworkSource>
          <ProgrammingLanguage>LAD</ProgrammingLanguage>
        </AttributeList>
        <ObjectList>
          <MultilingualText ID="4" CompositionName="Comment">
            <ObjectList>
              <MultilingualTextItem ID="5" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text />
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
          <MultilingualText ID="6" CompositionName="Title">
            <ObjectList>
              <MultilingualTextItem ID="7" CompositionName="Items">
                <AttributeList>
                  <Culture>en-US</Culture>
                  <Text>{{NETWORK_TITLE}}</Text>
                </AttributeList>
              </MultilingualTextItem>
            </ObjectList>
          </MultilingualText>
        </ObjectList>
      </SW.Blocks.CompileUnit>
    </ObjectList>
  </{{BLOCK_TYPE}}>
</Document>
